# telegram bot token from @botfather
BOT_TOKEN=your_telegram_bot_token_here

# virustotal api key from virustotal.com account settings
VT_API_KEY=your_virustotal_api_key_here

# mongodb connection string (mongodb atlas recommended for render)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/vtbot?retryWrites=true&w=majority

# render web service url (e.g. https://your-app.onrender.com)
# required for webhook mode in production
WEBHOOK_URL=https://your-app.onrender.com

# server port - render sets this automatically
PORT=3000

# set to production on render
NODE_ENV=development
